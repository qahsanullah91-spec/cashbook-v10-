# Backend database connection.
# Local development can use SQLite. Production/Vercel should use a managed PostgreSQL URL.
DATABASE_URL=sqlite:///./cashbook.db

# Comma-separated frontend origins allowed by CORS in local development.
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Regex for preview/production domains. Keep Vercel previews allowed without hardcoding localhost in production.
FRONTEND_ORIGIN_REGEX=^(https://[a-z0-9-]+\.vercel\.app|http://(localhost|127\.0\.0\.1):(5173|5174|3000|3001))$
