{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm --prefix frontend ci",
  "buildCommand": "npm --prefix frontend run build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/index.py": {
      "maxDuration": 30,
      "includeFiles": "backend/**",
      "excludeFiles": "backend/{.vendor/**,cashbook.db,tests/**,.pytest_cache/**,__pycache__/**}"
    }
  },
  "crons": [
    {
      "path": "/api/backup/daily",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/backup-sync",
      "schedule": "0 0 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/index"
    },
    {
      "source": "/health/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/api/upload",
      "destination": "/api/upload"
    },
    {
      "source": "/api/cron/:path*",
      "destination": "/api/cron/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
